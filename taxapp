<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>CM TaxApp | The Expert App for filing Taxes</title>
    
    <!-- Favicons & App Icons -->
    <link rel="icon" type="image/png" href="assets/logo.png">
    <link rel="apple-touch-icon" href="assets/logo.png">
    <link rel="shortcut icon" href="assets/logo.png">
    <meta name="theme-color" content="#f4f6f8">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="default">
    
    <!-- Fonts & Icons -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: { sans: ['Inter', 'sans-serif'] },
                    colors: {
                        brand: {
                            red: '#cc1a22',     /* Primary Red */
                            dark: '#1e2532',    /* Dark Navy for Help Banner */
                            text: '#374151',    /* Dark Grey for Text */
                            heading: '#111827', /* Almost Black for Headings */
                            muted: '#6b7280',   /* Muted Grey */
                            bg: '#f4f6f8',      /* App Background */
                            card: '#f8f9fa'     /* Light Grey for Service Cards */
                        }
                    },
                    boxShadow: {
                        'ios': '0 4px 20px rgba(0, 0, 0, 0.04)',
                        'card': '0 2px 10px rgba(0, 0, 0, 0.03)'
                    }
                }
            }
        }
    </script>
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #f4f6f8; -webkit-tap-highlight-color: transparent; }
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        
        /* Form Inputs */
        .hst-input, .hst-select {
            width: 100%; border: 1px solid #e5e7eb; border-radius: 10px; padding: 12px 14px;
            font-size: 14px; color: #111827; background: #fff; transition: all 0.2s; outline: none;
        }
        .hst-input:focus, .hst-select:focus { border-color: #cc1a22; box-shadow: 0 0 0 1px #cc1a22; }
        .file-upload-wrapper {
            position: relative; border: 1px dashed #d1d5db; border-radius: 10px; padding: 16px; text-align: center; background: #f9fafb; cursor: pointer; transition: all 0.2s;
        }
        .file-upload-wrapper:hover { border-color: #cc1a22; }
        .file-upload-wrapper input[type="file"] { position: absolute; top: 0; left: 0; width: 100%; height: 100%; opacity: 0; cursor: pointer; }

        /* Step Progress Line */
        .step-active { color: #cc1a22; font-weight: 700; border-bottom: 2px solid #cc1a22; }
        .step-inactive { color: #9ca3af; font-weight: 500; border-bottom: 2px solid transparent; }

        /* Animations */
        @keyframes fadeOut { to { opacity: 0; visibility: hidden; } }
        #splash { animation: fadeOut 0.5s ease-out 1.5s forwards; }
        @keyframes slideRight { from { transform: translateX(-100%); opacity: 0; } to { transform: translateX(0); opacity: 1; } }
        @keyframes slideUp { from { transform: translateY(50px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
    </style>
</head>
<body class="text-brand-text min-h-screen flex flex-col relative pb-24">

