    <!-- MULTI-STEP ITR FORM MODAL -->
    <div id="itrModal" class="fixed inset-0 z-[60] hidden flex-col bg-white">
        
        <!-- Modal Header -->
        <div class="px-6 py-5 border-b border-gray-100 flex justify-between items-center bg-white sticky top-0 z-10 shadow-sm">
            <h3 class="font-bold text-[16px] text-brand-heading">File ITR Return</h3>
            <button onclick="closeItrModal()" class="w-8 h-8 flex items-center justify-center bg-brand-card border border-gray-200 rounded-full text-gray-500 hover:text-brand-text">
                <i data-lucide="x" class="w-4 h-4"></i>
            </button>
        </div>

        <!-- Step Indicator -->
        <div class="px-6 pt-4 bg-white flex justify-between text-center border-b border-gray-100 pb-0 shadow-sm z-10">
            <div id="navStep1" class="w-1/3 pb-3 step-active text-[12px] transition-all duration-300">1. Personal</div>
            <div id="navStep2" class="w-1/3 pb-3 step-inactive text-[12px] transition-all duration-300">2. Income</div>
            <div id="navStep3" class="w-1/3 pb-3 step-inactive text-[12px] transition-all duration-300">3. Documents</div>
        </div>

        <!-- Form Body -->
        <div class="overflow-y-auto no-scrollbar p-6 bg-[#f4f6f8] flex-grow">
            <form id="itrForm" class="h-full max-w-[600px] mx-auto">
                
                <!-- SECTION 1: Personal Details -->
                <div id="step1" class="block animate-[fadeIn_0.3s_ease-out]">
                    <div class="bg-white p-5 rounded-2xl border border-gray-200 shadow-card space-y-4">
                        <div class="flex justify-between items-center mb-2">
                            <h4 class="text-[14px] font-bold text-brand-heading">Personal Details</h4>
                            <span class="text-[10px] bg-brand-card border border-gray-200 text-gray-700 px-2 py-1 rounded-md font-bold tracking-wider" id="appNoBadge"></span>
                        </div>
                        <div>
                            <label class="block text-[12px] text-brand-muted mb-1 font-semibold">Full Name *</label>
                            <input type="text" id="s1_name" class="hst-input uppercase" required>
                        </div>
                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label class="block text-[12px] text-brand-muted mb-1 font-semibold">Mobile *</label>
                                <input type="tel" id="s1_mobile" maxlength="10" class="hst-input" required>
                            </div>
                            <div>
                                <label class="block text-[12px] text-brand-muted mb-1 font-semibold">PAN *</label>
                                <input type="text" id="s1_pan" maxlength="10" class="hst-input uppercase font-mono" required>
                            </div>
                        </div>
                        <div>
                            <label class="block text-[12px] text-brand-muted mb-1 font-semibold">Email *</label>
                            <input type="email" id="s1_email" class="hst-input lowercase" required>
                        </div>
                        <div>
                            <label class="block text-[12px] text-brand-muted mb-1 font-semibold">IT Password (Optional)</label>
                            <input type="text" id="s1_password" class="hst-input">
                        </div>
                    </div>
                </div>

                <!-- SECTION 2: Income Details -->
                <div id="step2" class="hidden animate-[fadeIn_0.3s_ease-out]">
                    <div class="bg-white p-5 rounded-2xl border border-gray-200 shadow-card space-y-4">
                        <h4 class="text-[14px] font-bold text-brand-heading mb-2">Income Details</h4>
                        <div>
                            <label class="block text-[12px] text-brand-muted mb-1 font-semibold">Financial Year (FY) *</label>
                            <select id="s2_fy" class="hst-select font-semibold" required>
                                <option value="" disabled selected>Select FY</option>
                                <option value="2025-26">2025-26</option>
                                <option value="2024-25">2024-25</option>
                                <option value="2023-24">2023-24</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-[12px] text-brand-muted mb-1 font-semibold">Primary Head of Income *</label>
                            <select id="s2_head" class="hst-select" required>
                                <option value="" disabled selected>Select Income Source</option>
                                <option value="Salary">Salary</option>
                                <option value="Business">Business or Profession</option>
                                <option value="CapitalGains">Capital Gains</option>
                                <option value="HouseProperty">House Property</option>
                                <option value="Other">Other Sources</option>
                            </select>
                        </div>
                    </div>
                </div>

                <!-- SECTION 3: Documents Upload -->
                <div id="step3" class="hidden animate-[fadeIn_0.3s_ease-out]">
                    <div class="bg-white p-5 rounded-2xl border border-gray-200 shadow-card space-y-4">
                        <h4 class="text-[14px] font-bold text-brand-heading mb-1">Upload Documents</h4>
                        <p class="text-[11px] text-brand-muted mb-2">Uploads are optional but recommended.</p>
                        
                        <div class="grid grid-cols-2 gap-3">
                            <div class="file-upload-wrapper">
                                <i data-lucide="file-text" class="w-5 h-5 mx-auto text-gray-400 mb-2"></i>
                                <span class="text-[11px] font-semibold text-brand-text block">Bank Stmt</span>
                                <input type="file" id="s3_bank" accept=".pdf,image/*">
                            </div>
                            <div class="file-upload-wrapper">
                                <i data-lucide="file-badge" class="w-5 h-5 mx-auto text-gray-400 mb-2"></i>
                                <span class="text-[11px] font-semibold text-brand-text block">Form 16</span>
                                <input type="file" id="s3_form16" accept=".pdf,image/*">
                            </div>
                            <div class="file-upload-wrapper">
                                <i data-lucide="bar-chart-3" class="w-5 h-5 mx-auto text-gray-400 mb-2"></i>
                                <span class="text-[11px] font-semibold text-brand-text block">P&L Stmt</span>
                                <input type="file" id="s3_pnl" accept=".pdf,image/*">
                            </div>
                            <div class="file-upload-wrapper">
                                <i data-lucide="files" class="w-5 h-5 mx-auto text-gray-400 mb-2"></i>
                                <span class="text-[11px] font-semibold text-brand-text block">Others</span>
                                <input type="file" id="s3_others" accept=".pdf,image/*">
                            </div>
                        </div>
                    </div>
                </div>

            </form>
        </div>

        <!-- Modal Footer (Navigation) -->
        <div class="p-6 border-t border-gray-200 bg-white shadow-[0_-4px_20px_rgba(0,0,0,0.04)] pb-safe">
            <div class="flex gap-3 max-w-[600px] mx-auto">
                <button type="button" id="btnBack" onclick="prevStep()" class="w-1/3 bg-brand-card border border-gray-200 text-brand-text font-bold py-4 rounded-xl hidden transition hover:bg-gray-100 text-[14px]">
                    Back
                </button>
                <button type="button" id="btnNext" onclick="nextStep()" class="flex-1 bg-brand-dark text-white font-bold py-4 rounded-xl shadow-md transition hover:bg-black text-[14px]">
                    Save & Next
                </button>
                <button type="button" id="btnSubmit" onclick="submitItrFinal()" class="flex-1 bg-brand-red hover:bg-red-800 text-white font-bold py-4 rounded-xl shadow-md hidden transition text-[14px]">
                    Submit ITR
                </button>
            </div>
        </div>
    </div>

    <script>
        lucide.createIcons();

        // ⚠️ DEPLOYED APPS SCRIPT URL
        const SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbzLGxHi6ri31ajHoa-zntqhlgG2Ju1ID5-zIab73eOFCzChSPqO8l3o2DxQwwRdcfYh0g/exec';

        // -------------------------
        // UI TOGGLES
        // -------------------------
        function openMenu() { document.getElementById('sideMenu').classList.remove('hidden'); }
        function closeMenu() { document.getElementById('sideMenu').classList.add('hidden'); }

        function openSearch() {
            document.getElementById('searchModal').classList.remove('hidden');
            document.getElementById('searchModal').classList.add('flex');
            document.getElementById('searchInput').focus();
        }
        
        function closeSearch() {
            document.getElementById('searchModal').classList.add('hidden');
            document.getElementById('searchModal').classList.remove('flex');
            document.getElementById('searchInput').value = '';
            filterSearch(); 
        }

        function filterSearch() {
            let input = document.getElementById('searchInput').value.toLowerCase();
            let items = document.getElementsByClassName('search-item');
            let hasResults = false;

            for (let i = 0; i < items.length; i++) {
                let text = items[i].querySelector('.search-text').innerText.toLowerCase();
                if (text.includes(input)) {
                    items[i].style.display = "flex";
                    hasResults = true;
                } else {
                    items[i].style.display = "none";
                }
            }
            
            document.getElementById('searchResultsList').style.display = hasResults ? "block" : "none";
            document.getElementById('noResults').style.display = hasResults ? "none" : "block";
        }

        function openPopup(moduleName) {
            document.getElementById('popupTitle').innerText = moduleName;
            document.getElementById('contactPopup').classList.remove('hidden');
        }
        function closePopup() {
            document.getElementById('contactPopup').classList.add('hidden');
        }

        // -------------------------
        // ITR FORM & DATA LOGIC
        // -------------------------
        let currentStep = 1;

        function openItrModal() {
            document.getElementById('itrModal').classList.remove('hidden');
            document.getElementById('itrModal').classList.add('flex');
            
            if(!localStorage.getItem('itr_appNo')) {
                const now = new Date();
                const appNo = `ITR${String(now.getFullYear()).slice(-2)}${String(now.getMonth() + 1).padStart(2, '0')}${String(now.getDate()).padStart(2, '0')}${String(now.getHours()).padStart(2, '0')}`;
                localStorage.setItem('itr_appNo', appNo);
            }
            document.getElementById('appNoBadge').innerText = localStorage.getItem('itr_appNo');

            loadDrafts();
            showStep(1);
        }

        function closeItrModal() {
            document.getElementById('itrModal').classList.add('hidden');
            document.getElementById('itrModal').classList.remove('flex');
        }

        function saveCurrentSectionData() {
            if (currentStep === 1) {
                localStorage.setItem('itr_s1_name', document.getElementById('s1_name').value);
                localStorage.setItem('itr_s1_mobile', document.getElementById('s1_mobile').value);
                localStorage.setItem('itr_s1_pan', document.getElementById('s1_pan').value);
                localStorage.setItem('itr_s1_email', document.getElementById('s1_email').value);
                localStorage.setItem('itr_s1_password', document.getElementById('s1_password').value);
            } else if (currentStep === 2) {
                localStorage.setItem('itr_s2_fy', document.getElementById('s2_fy').value);
                localStorage.setItem('itr_s2_head', document.getElementById('s2_head').value);
            }
        }

        function loadDrafts() {
            document.getElementById('s1_name').value = localStorage.getItem('itr_s1_name') || 'MOHAMMED SHANID CM';
            document.getElementById('s1_mobile').value = localStorage.getItem('itr_s1_mobile') || '';
            document.getElementById('s1_pan').value = localStorage.getItem('itr_s1_pan') || '';
            document.getElementById('s1_email').value = localStorage.getItem('itr_s1_email') || '';
            document.getElementById('s1_password').value = localStorage.getItem('itr_s1_password') || '';
            document.getElementById('s2_fy').value = localStorage.getItem('itr_s2_fy') || '';
            document.getElementById('s2_head').value = localStorage.getItem('itr_s2_head') || '';
        }

        function showStep(step) {
            document.getElementById('step1').classList.add('hidden');
            document.getElementById('step2').classList.add('hidden');
            document.getElementById('step3').classList.add('hidden');
            
            document.getElementById('step' + step).classList.remove('hidden');

            for(let i=1; i<=3; i++) {
                const nav = document.getElementById('navStep'+i);
                if(i === step) {
                    nav.classList.add('step-active');
                    nav.classList.remove('step-inactive');
                } else {
                    nav.classList.remove('step-active');
                    nav.classList.add('step-inactive');
                }
            }

            const btnBack = document.getElementById('btnBack');
            const btnNext = document.getElementById('btnNext');
            const btnSubmit = document.getElementById('btnSubmit');

            if (step === 1) {
                btnBack.classList.add('hidden');
                btnNext.classList.remove('hidden');
                btnSubmit.classList.add('hidden');
            } else if (step === 2) {
                btnBack.classList.remove('hidden');
                btnNext.classList.remove('hidden');
                btnSubmit.classList.add('hidden');
            } else if (step === 3) {
                btnBack.classList.remove('hidden');
                btnNext.classList.add('hidden');
                btnSubmit.classList.remove('hidden');
            }
            currentStep = step;
        }

        function nextStep() {
            if (currentStep === 1) {
                if(!document.getElementById('s1_name').value || !document.getElementById('s1_mobile').value || !document.getElementById('s1_pan').value) {
                    alert("Please fill mandatory Personal Details to proceed."); return;
                }
            }
            if (currentStep === 2) {
                if(!document.getElementById('s2_fy').value || !document.getElementById('s2_head').value) {
                    alert("Please select mandatory Income Details to proceed."); return;
                }
            }
            saveCurrentSectionData();
            showStep(currentStep + 1);
        }

        function prevStep() {
            saveCurrentSectionData();
            showStep(currentStep - 1);
        }

        // --- APPS SCRIPT UPLOAD HELPERS ---
        function getFileTimestamp() {
            const now = new Date();
            const dd = String(now.getDate()).padStart(2, '0');
            const mm = String(now.getMonth() + 1).padStart(2, '0');
            const yyyy = now.getFullYear();
            return `${dd}${mm}${yyyy}`;
        }

        function createFileName(docType, originalName) {
            const name = document.getElementById('s1_name').value.trim().toUpperCase().replace(/[^A-Z0-9]/g, '');
            const fy = document.getElementById('s2_fy').value.trim();
            const ts = getFileTimestamp();
            const ext = originalName.split('.').pop();
            return `${docType}_${name}_FY_${fy}_${ts}.${ext}`;
        }

        function readFileAsBase64(file) {
            return new Promise((resolve, reject) => {
                const reader = new FileReader();
                reader.onload = () => resolve(reader.result.split(',')[1]);
                reader.onerror = error => reject(error);
                reader.readAsDataURL(file);
            });
        }

        // --- SUBMIT FUNCTION ---
        async function submitItrFinal() {
            const btn = document.getElementById('btnSubmit');
            btn.innerHTML = `<i data-lucide="loader-2" class="w-5 h-5 animate-spin"></i> Submitting...`;
            btn.disabled = true;
            lucide.createIcons();
            
            try {
                // Prepare Files
                const processFile = async (inputId, docType) => {
                    const fileInput = document.getElementById(inputId);
                    if (fileInput.files.length > 0) {
                        const file = fileInput.files[0];
                        const base64 = await readFileAsBase64(file);
                        const newName = createFileName(docType, file.name);
                        return { base64: base64, mimeType: file.type, fileName: newName };
                    }
                    return null;
                };

                const bankFile = await processFile('s3_bank', 'BANK_STATEMENT');
                const form16File = await processFile('s3_form16', 'FORM_16');
                const pnlFile = await processFile('s3_pnl', 'PNL_STATEMENT');
                const othersFile = await processFile('s3_others', 'OTHERS');

                // Build Payload matching Google Apps Script structure
                const payload = {
                    appNo: localStorage.getItem('itr_appNo'),
                    name: document.getElementById('s1_name').value.trim().toUpperCase(),
                    mobile: document.getElementById('s1_mobile').value,
                    pan: document.getElementById('s1_pan').value.toUpperCase(),
                    email: document.getElementById('s1_email').value.toLowerCase(),
                    password: document.getElementById('s1_password').value,
                    fy: document.getElementById('s2_fy').value,
                    headOfIncome: document.getElementById('s2_head').value,
                    bankFile: bankFile,
                    form16File: form16File,
                    pnlFile: pnlFile,
                    othersFile: othersFile
                };

                // Execute Network Request
                await fetch(SCRIPT_URL, {
                    method: 'POST',
                    body: JSON.stringify(payload),
                    mode: 'no-cors' // Bypasses CORS requirements
                });

                // Clear storage & redirect
                alert("ITR Details & Documents Submitted Successfully!");
                localStorage.clear();
                window.location.href = "pay.html";

            } catch (error) {
                console.error("Submission Error:", error);
                alert("Error submitting. Please try again.");
                btn.innerHTML = `Submit ITR`;
                btn.disabled = false;
            }
        }
    </script>
</body>
</html>
